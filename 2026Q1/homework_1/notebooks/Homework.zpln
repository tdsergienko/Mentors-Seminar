      "text": "%spark.pyspark\n\n# 2. Объединить orders с users и products\n\ndf = (\n    orders\n        .join(products, \"product_id\", how=\"inner\")\n        .join(users, \"user_id\", how=\"inner\")\n)\n\ndf.show()",
