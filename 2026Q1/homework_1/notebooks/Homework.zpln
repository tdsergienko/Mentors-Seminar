    {
      "text": "%spark.pyspark\n\n# 4. Для каждого города выбрать Top-2 товара по revenue_sum используя Window\n\nw = (\n    Window\n        .partitionBy(\"city\")\n        .orderBy(F.col(\"revenue_sum\").desc())\n)\n\ntop = (\n    metrics\n        .withColumn(\"rn\", F.row_number().over(w))\n        .filter(F.col(\"rn\") <= 2)\n        .drop(\"rn\")\n)\n\ntop.show()",
      "user": "anonymous",
      "dateUpdated": "2026-04-26T11:55:06+0000",
      "progress": 0,
      "config": {
        "editorSetting": {
          "language": "python",
          "editOnDblClick": false,
          "completionKey": "TAB",
          "completionSupport": true
        },
